+        let structure = [];
+        try { structure = JSON.parse(t.structure || '[]'); } catch(e) {}
+        
+        const payload = {};
+        
+        if (cardType === 'cover') {
+            payload.default_title = card.querySelector('input[name="default_title"]')?.value || '';
+            payload.classification = card.querySelector('select[name="classification"]')?.value || 'Confidential';
+            payload.footer_text = card.querySelector('input[name="footer_text"]')?.value || '';
+            payload.header_alignment = card.querySelector('select[name="header_alignment"]')?.value || 'center';
+            payload.client_logo = card.querySelector('input[name="client_logo"]')?.value || '';
+        } else if (cardType === 'background') {
+            payload.background_text = card.querySelector('textarea[name="background_text"]')?.value || '';
+        } else if (cardType === 'methodology') {
+            payload.methodology_text = card.querySelector('textarea[name="methodology_text"]')?.value || '';
+            await _saveTemplateSubsectionContents(card, 'methodology', structure);
+            payload.structure = JSON.stringify(structure);
+        } else if (cardType.startsWith('custom-')) {
