+async function deleteTechSubsection(sectionId, subsectionId) {
+    if (!confirm('Hapus sub bab ini?')) return;
+    try {
+        const res = await fetch(`/api/projects/${currentProjectId}`);
+        const p = await res.json();
+        
+        let projStructure = [];
+        try { 
+            const parsed = JSON.parse(p.technical_report || '[]'); 
+            if (Array.isArray(parsed)) projStructure = parsed;
+        } catch(e) {}
+        
+        let sec = projStructure.find(s => s.id === sectionId);
+        if (sec && sec.subsections) {
+            sec.subsections = sec.subsections.filter(sub => sub.id !== subsectionId);
+        }
+
+        const saveRes = await fetch(`/api/projects/${currentProjectId}`, {
+            method: 'PUT',
+            headers: { 'Content-Type': 'application/json' },
+            body: JSON.stringify({ technical_report: JSON.stringify(projStructure) })
+        });
+
+        if (saveRes.ok) {
+            viewProject(currentProjectId);
+        }
+    } catch(e) {
+        console.error(e);
+    }
+}
