+function getProjectFullStructure(p, tplStructure) {
+    let techReport = [];
+    try { techReport = JSON.parse(p.technical_report || '[]'); } catch(e) {}
+    
+    const isFullStructure = techReport.some(s => ['cover', 'background', 'toc', 'methodology', 'findings', 'appendix'].includes(s.id));
+    if (isFullStructure) {
+        return techReport;
+    } else {
+        let merged = JSON.parse(JSON.stringify(tplStructure));
+        techReport.forEach(customSec => {
+            let found = merged.find(s => s.id === customSec.id);
+            if (found) {
+                Object.assign(found, customSec);
+            } else {
+                merged.push(customSec);
+            }
+        });
+        return merged;
+    }
+}
