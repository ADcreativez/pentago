+async function moveWorkspaceChapter(idx, direction) {
+    try {
+        const res = await fetch(`/api/projects/${currentProjectId}`);
+        const p = await res.json();
+        
+        let tplStructure = [];
+        if (p.report_template_id) {
+            const tplRes = await fetch(`/api/report_templates/${p.report_template_id}?t=${Date.now()}`);
+            const tpl = await tplRes.json();
+            tplStructure = JSON.parse(tpl.structure || '[]');
+        }
+        let projStructure = getProjectFullStructure(p, tplStructure);
+        
+        if (idx + direction < 0 || idx + direction >= projStructure.length) return;
+        
+        // Swap
+        const temp = projStructure[idx];
+        projStructure[idx] = projStructure[idx + direction];
+        projStructure[idx + direction] = temp;
+
+        const saveRes = await fetch(`/api/projects/${currentProjectId}`, {
+            method: 'PUT',
+            headers: { 'Content-Type': 'application/json' },
+            body: JSON.stringify({ technical_report: JSON.stringify(projStructure) })
+        });
+
+        if (saveRes.ok) {
+            viewProject(currentProjectId);
+        }
+    } catch(e) {
+        console.error(e);
+    }
+}
