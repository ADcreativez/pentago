+async function saveCardEdits(cardId, cardType) {
+    if (!currentProjectId) return;
+    const card = document.getElementById(cardId);
+    if (!card) return;
+
+    try {
+        const res = await fetch(`/api/projects/${currentProjectId}`);
+        const p = await res.json();
+        
+        let tplStructure = [];
+        if (p.report_template_id) {
+            const tplRes = await fetch(`/api/report_templates/${p.report_template_id}?t=${Date.now()}`);
+            const tpl = await tplRes.json();
+            tplStructure = JSON.parse(tpl.structure || '[]');
+        }
+        let projStructure = getProjectFullStructure(p, tplStructure);
+        
+        const payload = {};
+
+        if (cardType === 'cover') {
+            payload.spk_number = card.querySelector('input[name="spk_number"]')?.value || '';
+            payload.report_version = card.querySelector('input[name="report_version"]')?.value || '1.0.0';
+            payload.report_date = card.querySelector('input[name="report_date"]')?.value || '';
+            payload.report_author = card.querySelector('input[name="report_author"]')?.value || '';
+            payload.client_logo = card.querySelector('input[name="client_logo"]')?.value || '';
+            payload.auditor_logo = card.querySelector('input[name="auditor_logo"]')?.value || '';
+            payload.use_watermark = card.querySelector('input[name="use_watermark"]')?.checked ? true : false;
+        } else if (cardType === 'pratinjau') {
+            const revisions = [];
+            card.querySelectorAll('[data-revision-row]').forEach(row => {
+                revisions.push({
+                    author: row.querySelector('input[name="rev_author"]')?.value || '',
+                    date: row.querySelector('input[name="rev_date"]')?.value || '',
+                    version: row.querySelector('input[name="rev_version"]')?.value || '',
+                    reference: row.querySelector('input[name="rev_reference"]')?.value || ''
+                });
+            });
+            payload.change_reference = JSON.stringify(revisions);
+
+            const approvals = [];
+            card.querySelectorAll('[data-approval-row]').forEach(row => {
+                approvals.push({
+                    name: row.querySelector('input[name="app_name"]')?.value || '',
+                    company: row.querySelector('input[name="app_company"]')?.value || '',
+                    approved: row.querySelector('input[name="app_approved"]')?.value || ''
+                });
+            });
+            payload.client_approver_name = JSON.stringify(approvals);
+        } else if (cardType === 'background') {
+            payload.summary = card.querySelector('textarea[name="summary"]')?.value || '';
+            payload.description = card.querySelector('textarea[name="description"]')?.value || '';
+            payload.scope = card.querySelector('input[name="scope"]')?.value || '';
+            payload.access_info = card.querySelector('textarea[name="access_info"]')?.value || '';
+            payload.out_of_scope = card.querySelector('textarea[name="out_of_scope"]')?.value || '';
+        } else if (cardType === 'methodology') {
+            payload.flow_description = card.querySelector('input[name="flow_description"]')?.value || '';
+        } else if (cardType === 'appendix') {
+            payload.appendix = card.querySelector('textarea[name="appendix"]')?.value || '';
+        } else if (cardType.startsWith('custom-')) {
+            const secId = cardType.replace('custom-', '');
+            let sec = projStructure.find(s => s.id === secId);
+            if (!sec) {
+                sec = { id: secId, title: 'Bab Kustom', content: '', subsections: [] };
+                projStructure.push(sec);
+            }
+            
+            const mainTa = card.querySelector(`textarea[name="${secId}_main"]`);
+            if (mainTa) sec.content = mainTa.value;
+        }
+
+        // Save subsections for ANY chapter that supports it (background, methodology, appendix, custom)
+        if (cardType !== 'cover' && cardType !== 'pratinjau' && cardType !== 'toc' && cardType !== 'findings') {
+            const secId = cardType.startsWith('custom-') ? cardType.replace('custom-', '') : cardType;
+            let sec = projStructure.find(s => s.id === secId);
+            if (sec) {
+                const subsections = [];
+                card.querySelectorAll('[data-subsection-block]').forEach(block => {
+                    const titleEl = block.querySelector('.subsection-title-text');
+                    const contentTa = block.querySelector('textarea');
+                    subsections.push({
+                        id: block.dataset.subsectionId || ('sub_' + Date.now()),
+                        title: titleEl?.textContent?.trim() || '',
+                        content: contentTa?.value || ''
+                    });
+                });
+                sec.subsections = subsections;
+                payload.technical_report = JSON.stringify(projStructure);
+            }
+        }
+
+        const saveRes = await fetch(`/api/projects/${currentProjectId}`, {
+            method: 'PUT',
+            headers: { 'Content-Type': 'application/json' },
+            body: JSON.stringify(payload)
+        });
+
+        if (saveRes.ok) {
+            alert('Perubahan berhasil disimpan!');
+            viewProject(currentProjectId);
+        } else {
+            alert('Gagal menyimpan perubahan.');
+        }
+    } catch(e) {
+        console.error(e);
+        alert('Error saving: ' + e.message);
+    }
+}
