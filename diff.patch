+// Additional helper functions for project workspace custom chapters
+async function addTechSubSection(sectionId) {
+    const title = prompt('Nama sub bab baru:');
+    if (!title || !title.trim()) return;
+
+    try {
+        const res = await fetch(`/api/projects/${currentProjectId}`);
+        const p = await res.json();
+        
+        let tplStructure = [];
+        if (p.report_template_id) {
+            const tplRes = await fetch(`/api/report_templates/${p.report_template_id}?t=${Date.now()}`);
+            const tpl = await tplRes.json();
+            tplStructure = JSON.parse(tpl.structure || '[]');
+        }
+        let projStructure = getProjectFullStructure(p, tplStructure);
+        
+        let sec = projStructure.find(s => s.id === sectionId);
+        if (!sec) {
+            sec = { id: sectionId, title: 'Bab Kustom', content: '', subsections: [] };
+            projStructure.push(sec);
+        }
+        
+        if (!sec.subsections) sec.subsections = [];
+        sec.subsections.push({
+            id: 'sub_' + Date.now(),
+            title: title.trim(),
+            content: ''
+        });
+
+        const saveRes = await fetch(`/api/projects/${currentProjectId}`, {
+            method: 'PUT',
+            headers: { 'Content-Type': 'application/json' },
