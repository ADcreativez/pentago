+async function _saveTemplateSubsectionContents(card, sectionId, structure) {
+    const cleanId = sectionId.replace('custom-', '');
+    const sec = structure.find(s => s.id === sectionId || ('custom-' + s.id) === sectionId || s.id === cleanId);
+    if (sec) {
+        const subsections = [];
+        card.querySelectorAll('[data-subsection-block]').forEach(block => {
+            const titleEl = block.querySelector('.subsection-title-text');
+            const contentTa = block.querySelector('textarea');
+            subsections.push({
+                id: block.dataset.subsectionId || ('sub_' + Date.now()),
+                title: titleEl?.textContent?.trim() || '',
+                content: contentTa?.value || ''
+            });
+        });
+        sec.subsections = subsections;
+    }
+}
