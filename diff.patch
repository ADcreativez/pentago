+// Modal handling
+function openReportTemplateModal(id = null) {
+    const modal = document.getElementById('report-template-modal');
+    if (!modal) return;
+    modal.classList.add('active');
+    
+    const form = document.getElementById('report-template-form');
+    form.reset();
+    document.getElementById('report-template-id').value = id || '';
+    document.getElementById('report-template-modal-title').innerText = id ? 'Edit Report Template' : 'Add Report Template';
+    
+    // Set up default outline structure if new template
+    let defaultStructure = [
+        { id: 'cover', title: 'Halaman Sampul', enabled: true },
+        { id: 'toc', title: 'Daftar Isi', enabled: true },
+        { id: 'background', title: '1. RINGKASAN EKSEKUTIF', enabled: true },
+        { id: 'methodology', title: '2. METODOLOGI', enabled: true },
+        { id: 'findings', title: '3. LAPORAN TEKNIS', enabled: true },
+        { id: 'appendix', title: '4. LAMPIRAN (APPENDIX)', enabled: true }
+    ];
+
+    if (id) {
+        fetch(`/api/report_templates/${id}?t=${Date.now()}`)
+            .then(res => res.json())
+            .then(t => {
+                document.getElementById('rt-name').value = t.name || '';
+                document.getElementById('rt-type').value = t.template_type || 'pentest';
+                document.getElementById('rt-title').value = t.default_title || '';
+                document.getElementById('rt-classification').value = t.classification || 'Confidential';
+                document.getElementById('rt-background').value = t.background_text || '';
+                document.getElementById('rt-methodology').value = t.methodology_text || '';
+                document.getElementById('rt-footer').value = t.footer_text || '';
+                let structure = [];
+                try { structure = JSON.parse(t.structure || '[]'); } catch(e) {}
+                if (structure.length === 0) structure = defaultStructure;
+                renderStructureEditor(structure);
+            });
+    } else {
+        document.getElementById('rt-background').value = "PT. Inovasi Informatika Indonesia (I-3) melakukan Vulnerability Assessment & Penetration Testing...";
+        document.getElementById('rt-methodology').value = "Pengujian mengikuti kerangka kerja standar seperti OWASP (Open Web Application Security Project) dan PTES...";
+        document.getElementById('rt-footer').value = "PentaGO Security Assessment Report";
+        renderStructureEditor(defaultStructure);
+    }
+}
+
+function closeReportTemplateModal() {
+    const modal = document.getElementById('report-template-modal');
+    if (modal) modal.classList.remove('active');
+}
+
+// Outline editor rendering inside the template modal form
+let currentStructure = [];
+function renderStructureEditor(structure) {
+    currentStructure = structure;
+    const container = document.getElementById('rt-structure-container');
+    if (!container) return;
+    container.innerHTML = '';
+    
+    structure.forEach((sec, idx) => {
+        const isDefault = ['cover', 'toc', 'background', 'methodology', 'findings', 'appendix'].includes(sec.id);
+        const upDisabled = idx === 0 ? 'disabled' : '';
+        const downDisabled = idx === structure.length - 1 ? 'disabled' : '';
+        
+        container.innerHTML += `
+            <div style="display:flex;align-items:center;gap:0.5rem;background:#fff;padding:0.5rem;border:1px solid var(--border-color);border-radius:4px;" data-chapter-index="${idx}">
+                <input type="checkbox" style="width:16px;height:16px;" ${sec.enabled !== false ? 'checked' : ''} onchange="currentStructure[${idx}].enabled = this.checked">
+                <input type="text" class="form-control" style="margin:0;font-size:0.85rem;padding:0.25rem 0.5rem;" value="${sec.title}" oninput="currentStructure[${idx}].title = this.value">
+                <div style="display:flex;gap:0.25rem;">
+                    <button type="button" class="btn btn-secondary" style="padding:0.2rem 0.4rem;height:24px;font-size:0.75rem;" ${upDisabled} onclick="moveChapter(${idx}, -1)">▲</button>
+                    <button type="button" class="btn btn-secondary" style="padding:0.2rem 0.4rem;height:24px;font-size:0.75rem;" ${downDisabled} onclick="moveChapter(${idx}, 1)">▼</button>
+                    ${!isDefault ? `<button type="button" class="btn btn-danger" style="padding:0.2rem 0.4rem;height:24px;font-size:0.75rem;" onclick="deleteChapter(${idx})">🗑</button>` : ''}
+                </div>
+            </div>
+        `;
+    });
+}
+
+function moveChapter(index, direction) {
+    const target = index + direction;
+    if (target < 0 || target >= currentStructure.length) return;
+    const temp = currentStructure[index];
+    currentStructure[index] = currentStructure[target];
+    currentStructure[target] = temp;
+    renderStructureEditor(currentStructure);
+}
+
+function deleteChapter(index) {
+    currentStructure.splice(index, 1);
+    renderStructureEditor(currentStructure);
+}
+
+function addNewCustomChapter() {
+    const title = prompt("Masukkan nama Bab Kustom baru:");
+    if (!title || !title.trim()) return;
+    currentStructure.push({
+        id: 'custom_' + Date.now(),
+        title: title.trim(),
+        enabled: true,
+        content: '',
+        subsections: []
+    });
+    renderStructureEditor(currentStructure);
+}
